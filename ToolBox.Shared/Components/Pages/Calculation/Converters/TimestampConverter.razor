@namespace ToolBox.Components.Pages.Converters
@inherits MvvmComponentBase<TimestampConverterVM>

<MudText Typo="Typo.body2" Class="mb-4">
    Unix 秒/毫秒与所选时区、UTC、ISO 8601 互转；输入时间戳时自动识别秒/毫秒（约 10 位 / 13 位）。
</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ViewModel.SetNow">当前时间</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="ViewModel.FromUnix">时间戳 → 时间</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ViewModel.FromTime">时间 → 时间戳</MudButton>
        <MudButton Variant="Variant.Text" OnClick="ViewModel.Clear">清空</MudButton>
    </MudStack>

    <MudSelect T="string"
               @bind-Value="ViewModel.SelectedTimeZoneId"
               Label="时区"
               Variant="Variant.Outlined"
               Dense="true"
               SearchBox="true"
               SearchBoxPlaceholder="搜索时区名称或 ID"
               Class="mb-4 ts-timezone-select">
        @foreach (var tz in TimestampConverterVM.TimeZoneOptions)
        {
            <MudSelectItem Value="@tz.Id">@tz.Label</MudSelectItem>
        }
    </MudSelect>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" GutterBottom="true">Unix 时间戳</MudText>
            <MudTextField T="string" Label="秒 (s)" @bind-Value="ViewModel.UnixSeconds"
                          Variant="Variant.Outlined" Immediate="true" Class="ts-input" />
            <MudTextField T="string" Label="毫秒 (ms)" @bind-Value="ViewModel.UnixMilliseconds"
                          Variant="Variant.Outlined" Immediate="true" Class="ts-input mt-3" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" GutterBottom="true">日期时间</MudText>
            <MudTextField T="string" Label="@ViewModel.LocalTimeLabel" @bind-Value="ViewModel.LocalTime"
                          Placeholder="2026-06-27 12:00:00"
                          Variant="Variant.Outlined" Immediate="true" Class="ts-input" />
            <MudTextField T="string" Label="UTC 时间" @bind-Value="ViewModel.UtcTime"
                          Placeholder="2026-06-27 04:00:00"
                          Variant="Variant.Outlined" Immediate="true" Class="ts-input mt-3" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="ISO 8601（所选时区偏移）" Value="ViewModel.Iso8601Local"
                          Variant="Variant.Outlined" ReadOnly="true" Class="ts-input" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="ISO 8601（UTC / Z）" Value="ViewModel.Iso8601Utc"
                          Variant="Variant.Outlined" ReadOnly="true" Class="ts-input" />
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrWhiteSpace(ViewModel.RelativeHint))
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">相对现在：@ViewModel.RelativeHint</MudAlert>
    }
</MudPaper>

@if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Dense="true">@ViewModel.ErrorMessage</MudAlert>
}
