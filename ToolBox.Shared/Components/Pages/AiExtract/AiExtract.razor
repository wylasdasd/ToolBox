@page "/ai-extract"

@namespace ToolBox.Components.Pages.AiExtract

@inherits MvvmComponentBase<AiExtractVM>

@using ToolBox.Services.Ai



<MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="4" Class="mb-4">

    <MudText Typo="Typo.h4">AI 结构化提取</MudText>

    <MudText Typo="Typo.body2">远程 AI（OpenRouter / DeepSeek / Kimi / Cursor），自定义模板，输出 JSON。</MudText>

</MudStack>



<MudPaper Class="pa-4 mb-4" Elevation="1">

    <MudText Typo="Typo.h6" GutterBottom="true">API 配置</MudText>

    <MudGrid>

        <MudItem xs="12" md="4">

            <MudSelect T="AiProviderKind" Label="提供商" @bind-Value="ViewModel.SelectedProvider" Variant="Variant.Outlined" Dense="true">

                @foreach (var p in ViewModel.Providers)

                {

                    <MudSelectItem Value="@p">@AiProviderCatalog.GetDisplayName(p)</MudSelectItem>

                }

            </MudSelect>

        </MudItem>

        <MudItem xs="12" md="4">

            <MudAutocomplete T="string"
                             Label="模型"
                             @bind-Value="ViewModel.Model"
                             SearchFunc="ViewModel.SearchModelsAsync"
                             CoerceText="true"
                             Strict="false"
                             ResetValueOnEmptyText="false"
                             Clearable="true"
                             MaxItems="30"
                             MinCharacters="0"
                             Variant="Variant.Outlined"
                             HelperText="@GetModelHelperText()">

                <ItemTemplate Context="modelId">

                    <div class="model-suggestion">

                        <MudText Typo="Typo.body2">@modelId</MudText>

                        @{

                            var desc = AiProviderModelCatalog.GetDescription(ViewModel.SelectedProvider, modelId);

                        }

                        @if (!string.IsNullOrWhiteSpace(desc))

                        {

                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@desc</MudText>

                        }

                    </div>

                </ItemTemplate>

            </MudAutocomplete>

        </MudItem>

        <MudItem xs="12" md="4">

            <MudTextField T="string" Label="API Key" @bind-Value="ViewModel.ApiKey" Variant="Variant.Outlined"

                          InputType="InputType.Password" />

        </MudItem>

        <MudItem xs="12">

            <MudStack Row="true" Spacing="2">

                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ViewModel.SaveApiKeyAsync">保存 Key</MudButton>

                <MudButton Variant="Variant.Outlined" OnClick="ViewModel.LoadApiKeyAsync">重新加载</MudButton>

                <MudButton Variant="Variant.Text" OnClick="ViewModel.ClearApiKeyAsync">清除 Key</MudButton>

            </MudStack>

        </MudItem>

    </MudGrid>

</MudPaper>



<MudPaper Class="pa-4 mb-4" Elevation="1">

    <MudText Typo="Typo.h6" GutterBottom="true">提取模板</MudText>

    <MudGrid>

        <MudItem xs="12" md="4">

            <MudSelect T="string" Label="预设模板" @bind-Value="ViewModel.SelectedTemplateId" Variant="Variant.Outlined" Dense="true">

                @foreach (var t in ViewModel.TemplatePresets)

                {

                    <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem>

                }

            </MudSelect>

        </MudItem>

        <MudItem xs="12">

            <MudTextField T="string" Label="系统提示（可选）" @bind-Value="ViewModel.SystemPrompt" Variant="Variant.Outlined" Lines="2" />

        </MudItem>

        <MudItem xs="12">

            <MudTextField T="string" Label="提取模板（描述目标 JSON 字段）" @bind-Value="ViewModel.ExtractTemplate"

                          Variant="Variant.Outlined" Lines="8" Class="mono-field" />

        </MudItem>

    </MudGrid>

</MudPaper>



<MudPaper Class="pa-4 mb-4" Elevation="1">

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4 pt-3">

        <MudTabPanel Text="粘贴文本" Icon="@Icons.Material.Filled.TextFields">

            <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-3">

                仅发送文本框内容，不会附带图片，也不会读取「批量文件」Tab 里的列表。适合试模板、调 prompt。

            </MudAlert>

            <MudTextField T="string" @bind-Value="ViewModel.SingleInputText" Label="待提取文本"

                          Variant="Variant.Outlined" Lines="12" Class="mono-field" />

            <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary"

                       Disabled="ViewModel.IsBusy" OnClick="ViewModel.RunSingleAsync">

                提取 JSON

            </MudButton>

        </MudTabPanel>



        <MudTabPanel Text="批量文件" Icon="@Icons.Material.Filled.FolderOpen">

            <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-3">
                可多选文件，或选择整个文件夹导入（DeepSeek 仅文本）。合并发送：多文件/多图一次请求，更快但不如逐条稳定。
            </MudAlert>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-wrap mb-3">
                <InputFile id="@BatchFilesInputId"
                           OnChange="ImportBatchFilesAsync"
                           multiple
                           accept=".txt,.log,.csv,.json,.md,.png,.jpg,.jpeg,.webp,.gif,.bmp"
                           disabled="@ViewModel.IsBusy"
                           style="display:none" />
                <MudButton HtmlTag="label"
                           UserAttributes="BatchFilesPickerLabelAttrs"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.NoteAdd"
                           Disabled="ViewModel.IsBusy">
                    选择文件
                </MudButton>
                @if (ViewModel.SupportsNativeFolderPicker)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CreateNewFolder"
                               Disabled="ViewModel.IsBusy"
                               OnClick="ViewModel.PickBatchFolderAsync">
                        选择文件夹
                    </MudButton>
                }
                else
                {
                    <InputFile id="@BatchFolderInputId"
                               OnChange="ImportBatchFilesAsync"
                               multiple
                               @attributes="FolderInputAttributes"
                               disabled="@ViewModel.IsBusy"
                               style="display:none" />
                    <MudButton HtmlTag="label"
                               UserAttributes="BatchFolderPickerLabelAttrs"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CreateNewFolder"
                               Disabled="ViewModel.IsBusy">
                        选择文件夹
                    </MudButton>
                }
                <MudCheckBox @bind-Value="ViewModel.MergeBatchSend" Label="合并发送" Disabled="ViewModel.IsBusy" Dense="true" />
            </MudStack>



            <MudText Typo="Typo.caption" Class="mb-3 mud-text-secondary">

                @ViewModel.MergeBatchHint。单文件上限 20MB，最多 500 个；关闭合并则逐文件请求。

            </MudText>



            @if (ViewModel.HasBatchItems)

            {

                <MudTable T="AiExtractVM.BatchInputItem" Items="ViewModel.BatchItems" Dense="true" Hover="true" Class="mb-3">

                    <HeaderContent>

                        <MudTh>类型</MudTh>

                        <MudTh>文件名</MudTh>

                    </HeaderContent>

                    <RowTemplate Context="item">

                        <MudTd>

                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(item.IsImage ? "图片" : "文本")</MudChip>

                        </MudTd>

                        <MudTd>@item.FileName</MudTd>

                    </RowTemplate>

                </MudTable>

            }



            <MudStack Row="true" Spacing="2" Class="flex-wrap">

                <MudButton Variant="Variant.Filled" Color="Color.Primary"

                           Disabled="ViewModel.IsBusy || !ViewModel.HasBatchItems" OnClick="ViewModel.RunBatchAsync">

                    批量提取

                </MudButton>

                <MudButton Variant="Variant.Outlined" Disabled="ViewModel.IsBusy || !ViewModel.HasBatchItems"

                           OnClick="ViewModel.ClearBatchItems">

                    清空列表

                </MudButton>

            </MudStack>



            @if (ViewModel.IsBusy && ViewModel.TotalCount > 0)

            {

                <MudProgressLinear Class="mt-3" Value="@ViewModel.ProgressPercent" Color="Color.Primary" />

                <MudText Typo="Typo.caption" Class="mt-1">@ViewModel.ProcessedCount / @ViewModel.TotalCount</MudText>

            }

        </MudTabPanel>

    </MudTabs>

</MudPaper>



<MudPaper Class="pa-4 mb-4" Elevation="1">

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2 flex-wrap">

        <MudText Typo="Typo.h6">JSON 输出</MudText>

        <MudSpacer />

        <MudButton Variant="Variant.Text" OnClick="ViewModel.ClearOutput">清空输出</MudButton>

    </MudStack>

    @if (!string.IsNullOrWhiteSpace(ViewModel.StatusMessage))

    {

        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">@ViewModel.StatusMessage</MudAlert>

    }

    <MudTextField T="string" Value="@ViewModel.OutputJson" Variant="Variant.Outlined" Lines="16" ReadOnly="true" Class="mono-field" />

    @if (!string.IsNullOrWhiteSpace(ViewModel.LogText))

    {

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">日志</MudText>

        <MudTextField T="string" Value="@ViewModel.LogText" Variant="Variant.Outlined" Lines="6" ReadOnly="true" Class="mono-field" />

    }

</MudPaper>



@code {

    private const string BatchFilesInputId = "ai-extract-batch-files";
    private const string BatchFolderInputId = "ai-extract-batch-folder";

    private static readonly Dictionary<string, object> BatchFilesPickerLabelAttrs = new()
    {
        ["for"] = BatchFilesInputId
    };

    private static readonly Dictionary<string, object> BatchFolderPickerLabelAttrs = new()
    {
        ["for"] = BatchFolderInputId
    };

    private static readonly Dictionary<string, object> FolderInputAttributes = new()

    {

        ["webkitdirectory"] = "",

        ["directory"] = ""

    };



    private async Task ImportBatchFilesAsync(InputFileChangeEventArgs e)
    {
        var (added, skipped) = await ImportBatchFilesCoreAsync(e);
        if (added + skipped > 0)
            ViewModel.NotifyBatchImportFinished(added, skipped);
    }

    private async Task<(int Added, int Skipped)> ImportBatchFilesCoreAsync(InputFileChangeEventArgs e)

    {

        var added = 0;

        var skipped = 0;



        foreach (var file in e.GetMultipleFiles(500))

        {

            if (!AiExtractVM.IsSupportedBatchFile(file.Name))

            {

                skipped++;

                continue;

            }



            try

            {

                await using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);

                await ViewModel.AddBatchFileAsync(file.Name, stream, file.ContentType, updateStatus: false);

                added++;

            }

            catch

            {

                skipped++;

            }

        }



        return (added, skipped);

    }



    private string GetModelHelperText()

    {

        if (ViewModel.SelectedProvider == AiProviderKind.Cursor)

            return "下拉选择或手动输入；Cursor Cloud Agent，支持图片（较慢）";



        return ViewModel.SupportsVision

            ? "下拉选择或手动输入；支持图片+文本"

            : "下拉选择或手动输入；仅文本";

    }

}


