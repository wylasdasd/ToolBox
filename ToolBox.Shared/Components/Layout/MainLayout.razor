@inherits LayoutComponentBase
@namespace ToolBox.Components.Layout

<MudThemeProvider Theme="_theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout >
    <MudAppBar >
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer"/>
        <MudText Typo="Typo.h6">ToolBox</MudText>
    
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Width="260px" Class="app-drawer">
        <div class="app-drawer-scroll">
            <NavMenu/>
        </div>
    </MudDrawer>

<MudMainContent Class="mt-4 mb-4">
        @* 使用 Container 可以自动处理响应式宽度，并提供更好的间距控制 *@
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-8">
          
                @Body
          
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = ToolBoxTheme.Default;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
