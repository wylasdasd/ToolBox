@page "/ocr-regex-batch"
@namespace ToolBox.Components.Pages.OcrRegexBatch
@inherits MvvmComponentBase<OcrRegexBatchVM>

<MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="4" Class="mb-4">
    <MudText Typo="Typo.h4">批量 OCR + 正则提取</MudText>
    <MudText>输入图片文件夹，批量识别并提取，支持导出 Excel(CSV) 与 JSON。</MudText>
</MudStack>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField @bind-Value="ViewModel.FolderPath"
                          Label="图片文件夹路径"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          HelperText="示例：C:\\data\\imgs（会递归扫描 jpg/png/bmp/tif/webp）" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Disabled="ViewModel.IsBusy"
                       OnClick="ViewModel.PickFolderAsync">
                选择文件夹
            </MudButton>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudSelect T="string" @bind-Value="ViewModel.OcrLanguage" Label="OCR 语言" Variant="Variant.Outlined">
                <MudSelectItem Value="@("zh-Hans")">中文</MudSelectItem>
                <MudSelectItem Value="@("en-US")">英文</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudCheckBox @bind-Value="ViewModel.IgnoreCase" Label="IgnoreCase" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudCheckBox @bind-Value="ViewModel.RemoveSpaces" Label="去掉空格" />
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-3" />
    <MudStack Row="true" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.h6">正则规则</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ViewModel.AddRule">新增规则</MudButton>
    </MudStack>

    <MudTable Items="ViewModel.Rules" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>字段名 Key</MudTh>
            <MudTh>Regex Pattern</MudTh>
            <MudTh>操作</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="字段名">
                <MudTextField @bind-Value="context.Key" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="Pattern">
                <MudTextField @bind-Value="context.Pattern" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTd>
            <MudTd DataLabel="操作">
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => ViewModel.RemoveRule(context))">删除</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="ViewModel.IsBusy"
                   OnClick="ViewModel.RunBatchAsync">
            @(ViewModel.IsBusy ? "批处理中..." : "开始批量处理")
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   Disabled="@(!ViewModel.HasResult)"
                   OnClick="ViewModel.ExportExcelAsync">
            导出 Excel(CSV)
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   Disabled="@(!ViewModel.HasResult)"
                   OnClick="ViewModel.ExportJsonAsync">
            导出 JSON
        </MudButton>
    </MudStack>

    <MudProgressLinear Class="mt-3" Color="Color.Primary" Value="ViewModel.ProgressPercent" />
    <MudText Typo="Typo.caption" Class="mt-1">
        进度：@ViewModel.ProcessedCount / @ViewModel.TotalCount（@ViewModel.ProgressPercent.ToString("0.##")%）
    </MudText>

    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
        @ViewModel.StatusMessage
    </MudAlert>
</MudPaper>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-2">日志</MudText>
            <MudTextField Value="ViewModel.LogText"
                          Variant="Variant.Outlined"
                          Lines="18"
                          ReadOnly="true" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-2">JSON 结果预览</MudText>
            <MudTextField Value="ViewModel.JsonResult"
                          Variant="Variant.Outlined"
                          Lines="18"
                          ReadOnly="true" />
        </MudPaper>
    </MudItem>
</MudGrid>
