@inherits LayoutComponentBase
@namespace ToolBox.Web.Client.Components.Layout
@using ToolBox.Components.Layout

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar>
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">ToolBox Web</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Width="260px" Class="app-drawer">
        <div class="app-drawer-scroll"><WebNavMenu /></div>
    </MudDrawer>
    <MudMainContent Class="mt-4 mb-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-8">@Body</MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = ToolBoxTheme.Default;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}